{
  "name": "hdilib",
  "version": "2.0.1",
  "port-version": 0,
  "description": "A C++ library for high-dimensional embeddings implementing tSNE and HSNE.",
  "dependencies": [
    { "name": "vcpkg-cmake", "host": true },
    { "name": "vcpkg-cmake-config", "host": true },
    "flann",
    "fmt",
    {
      "name": "glslang",
      "features": [ "tools" ],
      "host": true
    },
    {
      "name": "shaderc",
      "host": true
    }
  ],
  "default-features": [
    "kompute"
  ],
  "features": {
    "kompute": {
      "description": "Enable Vulkan/Kompute support",
      "dependencies": [
        "kompute"
      ]
    }
  },
  "overrides": [
    { "name": "kompute", "version": "0.10.0-a", "port-version": 3 }
  ]
}