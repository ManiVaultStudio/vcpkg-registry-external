{
  "name": "qt6",
  "version": "6.9.3",
  "description": "Selected pre-built qt binaries from Qt download - no viral licenses",
  "default-features": [
    "imageformats",
    "multimedia",
    "opengl-desktop",
    "positioning",
    "qt5compat",
    "serialport",
    "target-desktop",
    "webchannel",
    "webengine"
  ],
  "features": {
    "charts": {
      "description": "# Disabled - GPL"
    },
    "commercial": {
      "description": "Commercial licensing"
    },
    "datavis3d": {
      "description": "# Disabled - GPL"
    },
    "imageformats": {
      "description": "Read and write common image formats"
    },
    "multimedia": {
      "description": "QML types for multimedia content"
    },
    "networkauth": {
      "description": "# Disabled - GPL"
    },
    "opengl-desktop": {
      "description": "OpenGL desktop",
      "supports": "windows | osx | linux"
    },
    "opengl-dynamic": {
      "description": "OpenGL runtime loading"
    },
    "opengl-es2": {
      "description": "OpenGl ES2 (embedded) spec. "
    },
    "positioning": {
      "description": "in Qt6 this is required for webengine"
    },
    "qt5compat": {
      "description": "Retain compatibility with old Qt5ore API"
    },
    "qtwaylandcompositor": {
      "description": "# Disabled - GPL"
    },
    "serialport": {
      "description": "RS232 I/O support"
    },
    "target-android": {
      "description": "Android mobile"
    },
    "target-desktop": {
      "description": "Core desktop",
      "supports": "windows | osx | linux"
    },
    "target-ios": {
      "description": "Apple mobile"
    },
    "thin-arm64": {
      "description": "Make thin Qt for arm64 on macos",
      "supports": "osx"
    },
    "thin-x86-64": {
      "description": "Make thin Qt for x86_64 on macos",
      "supports": "osx"
    },
    "virtualkeyboard": {
      "description": "# Disabled - GPL"
    },
    "webchannel": {
      "description": "in Qt6 this is required for webengine"
    },
    "webengine": {
      "description": "Qt webbrowser"
    }
  }
}
