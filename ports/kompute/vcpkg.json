{
  "name": "kompute",
  "version": "0.10.0-a",
  "port-version": 3,
  "description": "General purpose GPU compute framework built on Vulkan to support 1000s of cross vendor graphics cards.",
  "homepage": "https://github.com/KomputeProject/kompute",
  "license": "Apache-2.0",
  "dependencies": [
    "fmt",
    "glfw3",
    {
      "name": "glslang",
      "host": true,
      "features": [
        "tools"
      ]
    },
    {
      "name": "shaderc",
      "host": true
    },
    "vcpkg-cmake",
    { 
      "name": "vcpkg-cmake-config",
      "host": true
    },
    "vulkan-headers",
    "vulkan-loader"
  ]
}
